<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ExpFood</title>



    <link rel="stylesheet" href="/styles.css">
    <style>
        body {
            display: flex;
            flex-direction: column;
            height: 100dvh;
            margin: 0;
        }
        #classes {
            flex: 1;
            margin-right: 10px;
        }
        #classes > * {
            padding-block: 5px;
        }
        #itens {
            flex: 4;
            display: grid;
            grid-template-columns: 1fr 1fr 1fr;
        }

        #itens > * {
            border: solid 1px black;
        }
    </style>
</head>
<body>

    
    <div style="height: 20%;">
        <%- include('../components/header') %>
    </div>
    
    <div style="height: 60%; overflow-y: scroll">
        <div style="display: flex;">

            <div id="classes"></div>
            
            <div id="itens"></div>
            
        </div>
    </div>

    
    <div style="height: 20%; overflow-y: scroll;">
        <%- include('./components/carrinho') %>
    </div>

    <!-- <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script> -->
    <script type="module" src="/cardapio/events.js"></script>

</body>
</html>