{
  "name": "printer",
  "version": "1.0.0",
  "main": "main.ts",
  "type": "module",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "electron-builder",
    "start2": "electron .",
    "start": "electron -r ts-node/register ."
  },
  "build": {
    "appId": "com.expressfood.agente",
    "productName": "ExpressFood Agente",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  },
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "net": "^1.0.2",
    "node-thermal-printer": "^4.6.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/node": "^25.4.0",
    "electron": "^40.8.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
