// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}






// ----------------------------------------------------------------------------------------------------------------------- nosso
model Plano {
  id    Int @id @default(autoincrement())
  nome String 
  preco  Decimal @db.Decimal(10, 2)
  qtd_licencas Int
  empresas Empresa[]
}







// ----------------------------------------------------------------------------------------------------------------------- estrutural
model Empresa {
  id    Int @id @default(autoincrement())
  nome_fantasia String 
  razao_social String 
  cnpj String 
  ativo Boolean @default(true)
  plano_id Int
  plano Plano @relation(fields: [plano_id], references: [id])
  horario_funcionamento HorarioDeFuncionamento[]
  usuarios Usuario[]
  classes Classe[]
  subitens Subitem[]
  itens Item[]
  promocoes Promocao[]
  vendas Pedido[]
  impressoras Impressora[]
  terminais Terminal[]
  mesas Mesa[]
  comandas Comanda[]
  senhas Senha[]
  estoque_movimentacao EstoqueMovimentacao[]
  estoque_posicao EstoquePosicao[]
}


model HorarioDeFuncionamento {
  id    Int @id @default(autoincrement())

  dia_id  Int
  dia   DiaDaSemana @relation(fields: [dia_id], references: [id], onDelete: Cascade)
  hora_abertura  String
  hora_fechamento  String

  empresa_id Int
  empresa Empresa @relation(fields: [empresa_id], references: [id])
  @@index([empresa_id])
}


model Impressora {
  id    Int @id @default(autoincrement())
  nome String 
  ip String 
  modelo String 
  
  empresa_id Int
  empresa Empresa @relation(fields: [empresa_id], references: [id])
  @@index([empresa_id])

  @@unique([nome, empresa_id]) 
}

enum TerminalTipo {
  POS 
  MOBILE
  PC
}
model Terminal {
  id      Int @id @default(autoincrement())
  nome    String 
  tipo    TerminalTipo 
  modelo  String? 

  pedidos Pedido[]
  
  empresa_id Int
  empresa Empresa @relation(fields: [empresa_id], references: [id])
  @@index([empresa_id])

  @@unique([nome, empresa_id]) 
}





model Usuario {
  id    Int @id @default(autoincrement())
  nome String 
  senha String 
  email String 
  telefone String 
  role Role @default(ADMIN_GERAL)

  ativo Boolean @default(true)
  
  empresa_id Int
  empresa Empresa @relation(fields: [empresa_id], references: [id])
  @@index([empresa_id])

  vendas Pedido[]

  @@unique([email, empresa_id]) 
}


enum Role {
  ADMIN_GERAL
  ADMIN_SEM_FINANCEIRO
  
  OPERADOR_GERAL
  OPERADOR_SEM_ESTOQUE
  OPERADOR_COM_FINANCEIRO

}








// ----------------------------------------------------------------------------------------------------------------------- itens, classes, subitens, vendaveis 


model Classe {
  id              Int @id @default(autoincrement())
  nome            String 
  index           Int @default(0)  // para order

  item            Item[]

  empresa_id      Int
  empresa         Empresa @relation(fields: [empresa_id], references: [id])
  @@index([empresa_id])

  @@unique([nome, empresa_id]) 
}

enum UnidadeMedida {
  // Unidades Contáveis (Mais comuns)
  UN    // Unidade
  CX    // Caixa
  PC    // Peça
  KT    // Kit
  DZ    // Dúzia
  FD    // Fardo

  // Unidades de Peso (Massa)
  KG    // Quilograma
  G     // Grama

  // Unidades de Volume (Líquidos/Gases)
  L     // Litro
  ML    // Mililitro

}

model Subitem {
  id                  Int @id @default(autoincrement())
  nome                String 
  ativo               Boolean @default(true)
  index Int @default(0) // para order


  // Unidades de Medida
  unidade_compra      UnidadeMedida?   // Ex: "CX" (Caixa), "FARDO", "KG"
  unidade_venda       UnidadeMedida?   // Ex: "UN" (Unidade), "UN", "G"
  
  // O "pulo do gato": Quantas unidades de venda vem em uma unidade de compra?
  // Ex: Se uma caixa vem 12 latas, o fator é 12.000
  fator_conversao    Decimal? @db.Decimal(10, 3)

  itens               ItemSubitem[]

  vendas              PedidoItemSubitem[] @relation("PedidoItemSubitem_Subitem")

  controla_estoque      Boolean @default(true)
  estoque_posicao       EstoquePosicao?
  estoque_movimentacao  EstoqueMovimentacao[]

  empresa_id      Int
  empresa         Empresa @relation(fields: [empresa_id], references: [id])
  @@index([empresa_id])

  @@unique([nome, empresa_id]) 

}

enum ItemTipo { 
  PRODUTO
  MERCADORIA 
  COMBO
}

model Item {
  id  Int @id @default(autoincrement())
  nome String 
  descricao String?  
  codigo_barras String? 
  preco Decimal @db.Decimal(10, 2)
  tipo  ItemTipo @default(MERCADORIA)
  ativo Boolean @default(true)
  index Int @default(0)  // para order

  empresa_id Int
  empresa Empresa @relation(fields: [empresa_id], references: [id])
  @@index([empresa_id])
  
  subitens ItemSubitem[]

  classe_id Int?
  classe Classe? @relation(fields: [classe_id], references: [id])

  promocao Promocao[]

 // Relação para combos
  combos_as_combo ComboItem[] @relation("ComboItens") // se este item é um combo que contém outros itens
  combos_as_item ComboItem[] @relation("ItemInCombos") // se este item faz parte de algum combo

  // relação com vendas
  vendas PedidoItem[]  

  @@unique([nome, empresa_id]) 
  
}

enum ItemSubitemTipo {
  MATERIA_PRIMA
  ADICIONAL
  AMBOS
}
model ItemSubitem {

  item_id Int
  item Item @relation(fields: [item_id], references: [id], onDelete: Cascade)

  subitem_id Int
  subitem Subitem @relation(fields: [subitem_id], references: [id])

  tipo ItemSubitemTipo

  quantidade Decimal @db.Decimal(10, 3)
  
  preco Decimal? @db.Decimal(10, 2)

  @@id([item_id, subitem_id])
}




// --------- combos

model ComboItem {
  combo_id Int
  combo    Item @relation("ComboItens", fields: [combo_id], references: [id], onDelete: Cascade)

  item_id  Int
  item     Item @relation("ItemInCombos", fields: [item_id], references: [id], onDelete: Cascade)

  quantidade Decimal @db.Decimal(10,3)

  @@id([combo_id, item_id])
  
}









// ----------------------------------------------------------------------------------------------------------------------- estoque


enum EstoqueMovimentacaoTipo {
  ENTRADA
  SAIDA
  AJUSTE
  VENDA
}
model EstoqueMovimentacao {
  id            String   @id @default(uuid())

  subitem_id    Int
  subitem       Subitem @relation(fields: [subitem_id], references: [id], onDelete: Cascade)

  tipo          EstoqueMovimentacaoTipo @default(ENTRADA)
  quantidade    Decimal @db.Decimal(10, 3) @default(0)
  referencia    String?   //    pedido:123    compra:45    inventario:2026-03-16

  // Por que isso? Porque o custo do item muda. 
  // Daqui a um ano, você vai querer saber quanto pagou 
  // naquela ENTRADA específica de 2024.
  // REGRA DE OURO: O saldo no banco de dados deve ser SEMPRE na Unidade de Venda.
  custo_unitario_momento Decimal? @db.Decimal(10, 2) 


  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  empresa_id    Int
  empresa       Empresa @relation(fields: [empresa_id], references: [id])
  @@index([empresa_id])
}


model EstoquePosicao {
  id               Int   @id @default(autoincrement())
  
  // Relação com o seu Item/Produto existente
  subitem_id          Int   @unique // @unique garante que cada item tenha apenas uma linha de posição
  subitem             Subitem     @relation(fields: [subitem_id], references: [id], onDelete: Cascade)

  // Quantidades
  // REGRA DE OURO: O saldo no banco de dados deve ser SEMPRE na Unidade de Venda.
  // Se você tem 2 caixas de 12, no banco deve constar 24.
  // o ESTOQUE_ATUAL deve ser a quantidade_fisica - quantidade_reserva (reserva serve par deliveries, por exemplo)
  quantidade_fisica Decimal  @default(0) @db.Decimal(10, 3) // Usar Decimal para evitar erros de precisão (ex: kg)
  quantidade_reserva Decimal  @default(0) @db.Decimal(10, 3) // Itens vendidos mas não despachados
  
  // Controle de Reposição
  estoque_minimo    Decimal  @default(0) @db.Decimal(10, 3)
  estoque_maximo    Decimal? @db.Decimal(10, 3)

  // Valores Financeiros (Opcional, mas recomendado para Posição de Estoque) REGRA DE OURO: O saldo no banco de dados deve ser SEMPRE na Unidade de Venda.
  // custoUnitario: É o valor que você pagou por uma unidade de venda do produto (já considerando o fator de conversão).
  custo_unitario    Decimal  @default(0) @db.Decimal(10, 2)

  // Auditoria
  ultima_contagem   DateTime? // Data do último inventário físico
  updated_at        DateTime  @updatedAt
  created_at        DateTime  @default(now())

  
  empresa_id    Int
  empresa       Empresa @relation(fields: [empresa_id], references: [id])
  @@index([empresa_id])

}





// ----------------------------------------------------------------------------------------------------------------------- promocoes

model Promocao {
  id               Int   @id @default(autoincrement())
  empresa_id     Int
  empresa       Empresa @relation(fields: [empresa_id], references: [id])
  
  preco_promocional Decimal  @db.Decimal(10, 2)
  hora_inicio        String   // "18:00"
  hora_fim          String   // "23:59"
  ativo         Boolean  @default(true)

  // dia_da_semana_id    Int
  // dia_da_semana       DiaDaSemana @relation(fields: [dia_da_semana_id], references: [id], onDelete: Cascade)
  seg       Boolean @default(false)
  ter       Boolean @default(false)
  qua       Boolean @default(false)
  qui       Boolean @default(false)
  sex       Boolean @default(false)
  sab       Boolean @default(false)
  dom       Boolean @default(false)

  item_id       Int
  item          Item  @relation(fields: [item_id], references: [id], onDelete: Cascade)

  @@index([empresa_id])
  @@index([item_id])
}

model DiaDaSemana {
  id Int @id @default(autoincrement())
  nome_completo String
  nome_abreviado String
  nome_enum DayOfWeek

  horario_funcionamento HorarioDeFuncionamento[]
}

enum DayOfWeek {
  SEGUNDA
  TERCA
  QUARTA
  QUINTA
  SEXTA
  SABADO
  DOMINGO
}





// ----------------------------------------------------------------------------------------------------------------------- formatos de venda


// ------------------- mesa
model Mesa {
  id            Int   @id @default(autoincrement())
  nome          String      // Número da mesa (Ex: Mesa 01, Mesa 02)

  empresa_id    Int
  empresa       Empresa @relation(fields: [empresa_id], references: [id])
  @@index([empresa_id])

  status        MesaStatus @default(LIVRE)

  pedidos        Pedido[]

  updated_at    DateTime @updatedAt

  @@unique([nome, empresa_id]) 
}


enum MesaStatus {
  LIVRE       // Livre
  OCUPADA     // Ocupada (Cliente sentado)
  CONTA       // Pediu a conta
}


// ------------------- comanda
model Comanda {
  id            String   @id @default(uuid())

  nome          String?

  empresa_id    Int
  empresa       Empresa @relation(fields: [empresa_id], references: [id])
  @@index([empresa_id])

  status        ComandaStatus @default(OCUPADA)

  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  pedidos        Pedido[]

  @@unique([nome, empresa_id])
}


enum ComandaStatus {
  OCUPADA     // Ocupada (Cliente sentado)
  CONTA
  PAGA        // pagou
}


// ------------------- senha
model Senha {
  id            String   @id @default(uuid())
  numero        Int?
  nome          String?
  
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  empresa_id    Int
  empresa       Empresa @relation(fields: [empresa_id], references: [id])
  @@index([empresa_id])

  pedidos        Pedido[]

  @@unique([numero, empresa_id])
}








// ----------------------------------------------------------------------------------------------------------------------- pedidos (vendas)

enum PedidoStatus {
  PENDENTE
  PAGA
  CANCELADA
}

enum PedidoFormato {
  MESA
  SENHA
  COMANDA
}

model Pedido {
  id            String      @id @default(uuid())
  
  empresa_id    Int
  empresa       Empresa @relation(fields: [empresa_id], references: [id])
  @@index([empresa_id])

  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
  status        PedidoStatus @default(PENDENTE)
  total         Decimal  @db.Decimal(10, 2)
  desconto      Decimal @db.Decimal(10, 2) @default(0) // desconto total da venda

  observacao    String? // qualquer coisa que o cliente peca pro pedido todo

  itens         PedidoItem[]

  // formato de trabalho = MESAS
  mesa_id       String?
  mesa          Mesa?  @relation(fields: [mesa_id, empresa_id], references: [nome, empresa_id])

  // formato de trabalho = COMANDAS
  comanda_id    String?
  comanda       Comanda?  @relation(fields: [comanda_id, empresa_id], references: [nome, empresa_id])

  // formato de trabalho = SENHAS
  senha_id      Int?
  senha         Senha?  @relation(fields: [senha_id, empresa_id], references: [numero, empresa_id])

  // vai ser preenchido so quando a venda for terminada pra depois usarmos pra filtrar relatorios
  formato       PedidoFormato? 

  // vai ser preenchido so quando a venda for terminada pra depois usarmos pra filtrar relatorios
  terminal_id   Int?
  terminal      Terminal? @relation(fields: [terminal_id], references: [id], onDelete: SetNull) 

  usuario_id    Int
  usuario       Usuario @relation(fields: [usuario_id], references: [id])
  @@index([usuario_id])

	@@map("Pedido")
}

model PedidoItem {
  id            String      @id @default(uuid())
  pedido_id     String
  pedido        Pedido    @relation(fields: [pedido_id], references: [id], onDelete: Cascade)
  
  observacao    String? // qualquer coisa que o cliente peca pro item do pedido (sem alguma coisa ou esquentar mais , sei la)

  item_id       Int
  item          Item     @relation(fields: [item_id], references: [id])

  quantidade    Decimal @db.Decimal(10,3)
  preco         Decimal  @db.Decimal(10,2) // preço do item original
  desconto      Decimal @db.Decimal(10,2)  @default(0) // desconto aplicado nesse item específico

  subitens      PedidoItemSubitem[]
	@@map("PedidoItem")
}

model PedidoItemSubitem {
  id               String      @id @default(uuid())
  pedido_item_id   String
  pedido_item      PedidoItem @relation(fields: [pedido_item_id], references: [id], onDelete: Cascade)

  subitem_id       Int
  subitem          Subitem   @relation("PedidoItemSubitem_Subitem", fields: [subitem_id], references: [id])

  quantidade       Decimal   @db.Decimal(10,3)
  preco            Decimal   @db.Decimal(10,2)
  desconto         Decimal   @db.Decimal(10,2) @default(0)
 
	@@map("PedidoItemSubitem")
}