// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------------------------------------------------------------------------- nosso
model Plano {
  id           Int       @id
  nome         String
  preco        Decimal   @db.Decimal(10, 2)
  qtd_licencas Int
  empresas     Empresa[]
}

enum CRT {
  SIMPLES_NACIONAL         // 1
  SIMPLES_NACIONAL_EXCESSO // 2
  REGIME_NORMAL            // 3
}

enum AmbienteFiscal {
  PRODUCAO
  HOMOLOGACAO
}

enum TipoComercio {
  RESTAURANTE
  PIZZARIA
  CHURRASCARIA
  FAST_FOOD
  LANCHONETE
  PADARIA
  CAFE
  SORVETERIA
  CANTINA_ESCOLAR
  CONVENIENCIA
  DISTRIBUIDORA
  BAR
  CASA_NOTURNA
  FOOD_TRUCK
  HAMBURGUERIA
  SUSHI
  OUTRO
}

// ----------------------------------------------------------------------------------------------------------------------- estrutural
model Empresa {
  id            Int     @id @default(autoincrement())
  nome_fantasia String
  razao_social  String
  cnpj          String  @unique
  ativo         Boolean       @default(true)
  logo_url      String?
  tipo_comercio TipoComercio?

  // Fiscal
  usa_fiscal          Boolean        @default(false) // se false, sistema não exige dados fiscais nos itens
  inscricao_estadual  String?        // "ISENTO" se isento
  inscricao_municipal String?        // para NFS-e (serviços)
  crt                 CRT            @default(SIMPLES_NACIONAL)
  ambiente_fiscal     AmbienteFiscal @default(HOMOLOGACAO)
  serie_nfce          Int            @default(1)
  proximo_numero_nfce Int            @default(1)

  endereco_id Int      @unique
  endereco    Endereco @relation(fields: [endereco_id], references: [id])

  plano_id              Int
  plano                 Plano                    @relation(fields: [plano_id], references: [id])
  horario_funcionamento HorarioDeFuncionamento[]
  usuarios              Usuario[]
  classes               Classe[]
  subitens              Subitem[]
  itens                 Item[]
  promocoes             Promocao[]
  vendas                Pedido[]
  impressoras           Impressora[]
  terminais             Terminal[]
  mesas                 Mesa[]
  comandas              Comanda[]
  senhas                Senha[]
  estoque_movimentacao  EstoqueMovimentacao[]
  estoque_posicao       EstoquePosicao[]
  forma_pagamentos      EmpresaFormaPagamento[]
  taxas_cartao          TaxaCartao[]
  provedores_pagamento  ProvedorPagamento[]
  clientes              Cliente[]
  grupos_fiscais        GrupoFiscal[]
  motoboys              Motoboy[]
  zonas_entrega         ZonaEntrega[]
  eventos               Evento[]
}

model Endereco {
  id         Int       @id @default(autoincrement())
  rua        String
  numero     String   // string pq pode ser 150a ou 150-B 
  cep        String
  bairro     String
  cidade     String
  estado     String
  pais       String    @default("Brasil")
  empresa    Empresa?
  cliente    Cliente?  @relation(fields: [cliente_id], references: [id])
  cliente_id Int?

  pedidos_entrega Pedido[] @relation("EnderecoEntrega")
}

enum ClienteGenero {
  M
  F
  O
}

model Cliente {
  id        Int            @id @default(autoincrement())
  nome      String
  cpf       String?
  telefone  String
  genero    ClienteGenero?
  enderecos Endereco[]
  pedidos   Pedido[]
  comandas  Comanda[]

  empresa_id Int
  empresa    Empresa @relation(fields: [empresa_id], references: [id])

  @@unique([cpf, empresa_id])
  @@index([empresa_id])
}

model HorarioDeFuncionamento {
  id Int @id @default(autoincrement())

  dia_id          Int
  dia             DiaDaSemana @relation(fields: [dia_id], references: [id], onDelete: Cascade)
  hora_abertura   String
  hora_fechamento String

  empresa_id Int
  empresa    Empresa @relation(fields: [empresa_id], references: [id])

  @@index([empresa_id])
}

enum ImpressoraTipo {
  COZINHA
  BALCAO
  RECIBO
}

model Impressora {
  id     Int            @id @default(autoincrement())
  nome   String
  ip     String
  modelo String
  tipo   ImpressoraTipo @default(COZINHA)

  empresa_id Int
  empresa    Empresa @relation(fields: [empresa_id], references: [id], onDelete: Cascade)

  @@unique([nome, empresa_id])
  @@index([empresa_id])
}

model Usuario {
  id       Int    @id @default(autoincrement())
  nome     String
  senha    String
  email    String
  telefone String
  role     Role   @default(ADMIN_GERAL)

  ativo      Boolean @default(true)
  session_id String?

  ultimo_login_terminal_id Int?

  empresa_id Int
  empresa    Empresa @relation(fields: [empresa_id], references: [id], onDelete: Cascade)

  vendas Pedido[]

  @@unique([email])
  @@index([empresa_id])
}

enum Role {
  OWNER
  ADMIN_GERAL
  ADMIN_SEM_FINANCEIRO

  OPERADOR_GERAL
  OPERADOR_SEM_ESTOQUE
  OPERADOR_COM_FINANCEIRO

  AUTOATENDIMENTO

  CONTADOR
}

enum TerminalTipo {
  POS
  ADM
  PDV
  DELIVERY
  ENTRADA
  SAIDA
  KDS
  AUTO_TOTEM //auto de autoatendimento
  AUTO_TABLET //auto de autoatendimento

}

enum DeliveryStatus {
  RECEBIDO
  CONFIRMADO
  EM_PRODUCAO
  AGUARDANDO_MOTOBOY
  A_CAMINHO
  ENTREGUE
  CANCELADO
}

enum CanalOrigem {
  WHATSAPP
  TELEFONE
  APP_PROPRIO
  BALCAO
}

model Terminal {
  id     Int          @id @default(autoincrement())
  nome   String
  tipo   TerminalTipo
  modelo String?
  ativo  Boolean      @default(true)

  faz_pagamento Boolean @default(false) // se true, terminal exige que cada venda tenha um pagamento associado (caixa, PDV)
  img_fundo_url String?       // para terminal de autoatendimento, a imagem de fundo do app

  pedidos Pedido[]

  empresa_id Int
  empresa    Empresa @relation(fields: [empresa_id], references: [id], onDelete: Cascade)

  provedor_padrao_id Int?
  provedor_padrao    ProvedorPagamento? @relation(fields: [provedor_padrao_id], references: [id])

  pedido_pagamentos PedidoPagamento[]

  ultimo_login_data       DateTime?
  ultimo_login_usuario_id Int?

  @@unique([nome, empresa_id])
  @@index([empresa_id])
}

// ----------------------------------------------------------------------------------------------------------------------- moedas

enum TipoFormaPagamento {
  DINHEIRO
  PIX
  CARTAO_DEBITO
  CARTAO_CREDITO
  VOUCHER
  OUTRO
}

model FormaPagamentoGlobal {
  id                   Int                @id
  nome                 String // Ex: Dinheiro, PIX, Crédito
  tipo                 TipoFormaPagamento
  exige_troco          Boolean            @default(false)
  permite_parcelamento Boolean            @default(false)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  empresas EmpresaFormaPagamento[] // relação many-to-many
}

model EmpresaFormaPagamento {
  id                 Int     @id @default(autoincrement())
  empresa_id         Int
  forma_pagamento_id Int
  ativo              Boolean @default(true) // ativo para a empresa

  empresa            Empresa              @relation(fields: [empresa_id], references: [id], onDelete: Cascade)
  forma_pagamento    FormaPagamentoGlobal @relation(fields: [forma_pagamento_id], references: [id], onDelete: Cascade)
  pedidos_pagamentos PedidoPagamento[]

  @@unique([empresa_id, forma_pagamento_id]) // chave composta
}

enum TipoCartao {
  DEBITO
  CREDITO
  PIX
}

model Bandeira {
  id   Int    @id @default(autoincrement())
  nome String // VISA, MASTERCARD, ELO

  taxas             TaxaCartao[]
  pedido_pagamentos PedidoPagamento[]
}

model ProvedorPagamento {
  id               Int    @id @default(autoincrement())
  nome             String
  nome_normalizado String

  empresa_id Int
  empresa    Empresa @relation(fields: [empresa_id], references: [id], onDelete: Cascade)

  terminais         Terminal[]
  taxas             TaxaCartao[]
  pedido_pagamentos PedidoPagamento[]

  @@unique([nome_normalizado, empresa_id])
}

model TaxaCartao {
  id Int @id @default(autoincrement())

  provedor_id Int
  provedor    ProvedorPagamento @relation(fields: [provedor_id], references: [id], onDelete: Cascade)

  bandeira_id       Int?
  bandeira          Bandeira?  @relation(fields: [bandeira_id], references: [id])
  tipo              TipoCartao
  parcelas          Int        @default(1)
  prazo_recebimento Int        @default(30) // dias (2, 14, 30...)

  taxa_percentual Decimal  @db.Decimal(5, 2)
  taxa_fixa       Decimal? @db.Decimal(10, 2)

  empresa_id Int
  empresa    Empresa @relation(fields: [empresa_id], references: [id], onDelete: Cascade)

  @@unique([provedor_id, bandeira_id, tipo, parcelas])
  @@index([empresa_id])
}

model PedidoPagamento {
  id Int @id @default(autoincrement())

  valor         Decimal @db.Decimal(10, 2)
  valor_liquido Decimal @db.Decimal(10, 2) // valor - taxa aplicada (para facilitar para relatorios)

  troco_para Decimal?

  terminal_id Int?
  terminal    Terminal? @relation(fields: [terminal_id], references: [id])

  // 🔥 NOVO
  provedor_id Int?
  provedor    ProvedorPagamento? @relation(fields: [provedor_id], references: [id])

  bandeira_id Int?
  bandeira    Bandeira? @relation(fields: [bandeira_id], references: [id])

  parcelas      Int?
  taxa_aplicada Decimal? // taxa usada nezta venda (pq na tabela Terminal tbm tem taxa, mas aquela eh a taxa atual que pode mudar, e aqui eh ums snapshot)

  pedido_id                  String
  pedido                     Pedido                @relation(fields: [pedido_id], references: [id])
  empresa_forma_pagamento_id Int
  forma_pagamento            EmpresaFormaPagamento @relation(fields: [empresa_forma_pagamento_id], references: [id])
}

// ----------------------------------------------------------------------------------------------------------------------- itens, classes, subitens, vendaveis 

model Classe {
  id    Int    @id @default(autoincrement())
  nome  String
  index Int    @default(0) // para order

  item Item[]

  empresa_id Int
  empresa    Empresa @relation(fields: [empresa_id], references: [id], onDelete: Cascade)

  @@unique([nome, empresa_id])
  @@index([empresa_id])
}

enum UnidadeMedida {
  // Unidades Contáveis (Mais comuns)
  UN // Unidade
  CX // Caixa
  PC // Peça
  KT // Kit
  DZ // Dúzia
  FD // Fardo

  // Unidades de Peso (Massa)
  KG // Quilograma
  G // Grama

  // Unidades de Volume (Líquidos/Gases)
  L // Litro
  ML // Mililitro
}

model Subitem {
  id    Int     @id @default(autoincrement())
  nome  String
  ativo Boolean @default(true)
  index Int     @default(0) // para order

  // Unidades de Medida
  unidade_compra UnidadeMedida? // Ex: "CX" (Caixa), "FARDO", "KG"
  unidade_venda  UnidadeMedida? // Ex: "UN" (Unidade), "UN", "G"

  // O "pulo do gato": Quantas unidades de venda vem em uma unidade de compra?
  // Ex: Se uma caixa vem 12 latas, o fator é 12.000
  fator_conversao Decimal? @db.Decimal(10, 3)

  itens ItemSubitem[]

  vendas PedidoItemSubitem[] @relation("PedidoItemSubitem_Subitem")

  controla_estoque     Boolean               @default(true)
  estoque_posicao      EstoquePosicao?
  estoque_movimentacao EstoqueMovimentacao[]

  empresa_id Int
  empresa    Empresa @relation(fields: [empresa_id], references: [id], onDelete: Cascade)

  @@unique([nome, empresa_id])
  @@index([empresa_id])
}

enum ItemTipo {
  PRODUTO
  MERCADORIA
  COMBO
  INGRESSO
  ENTRADA
}


/**
Minha recomendação (não é pra fazer agora, só pra você decidir)
Frontend constants para: cfop, csosn, cst_icms, cst_pis, cst_cofins, origem

→ São listas pequenas, extremamente estáveis. Profissionais de fiscal já conhecem esses códigos. Não justifica nenhuma tabela.

Para restaurante, o CFOP se resume a 3 opções práticas:

5101 — venda do que foi produzido no estabelecimento
5102 — venda de mercadoria adquirida de terceiros (revenda)
5405 — venda com substituição tributária
Campo de texto livre para: ncm e cest

→ São milhares de códigos. O profissional de fiscal/contador da empresa sabe o NCM dos produtos dela. Um dropdown de 10.000 itens é pior que digitar.

Opcional no futuro: autocomplete de NCM via API do governo (têm APIs públicas gratuitas para consulta de NCM por descrição) — mas isso é feature, não necessidade inicial.
*/

// Perfil fiscal reutilizável — o usuário cria uma vez e aplica em vários itens
model GrupoFiscal {
  id   Int    @id @default(autoincrement())
  nome String // Ex: "Alimentos", "Bebidas", "Sobremesas"

  // NCM / CFOP / CEST
  ncm  String  // 8 dígitos: ex "21069090" (tabela TIPI)
  cfop String  // 4 dígitos: ex "5102" (venda mercadoria no estado)
  cest String? // 7 dígitos: só quando há Substituição Tributária
  origem Int @default(0) // 0=Nacional, 1=Estrangeira importação direta...

  // ICMS — preenche csosn OU cst_icms dependendo do CRT da empresa
  csosn         String?  // Simples Nacional: "400", "500", "900"...
  cst_icms      String?  // Regime Normal: "00", "20", "40"...
  aliquota_icms Decimal? @db.Decimal(5, 2)

  // PIS / COFINS
  cst_pis         String?
  aliquota_pis    Decimal? @db.Decimal(5, 2)
  cst_cofins      String?
  aliquota_cofins Decimal? @db.Decimal(5, 2)

  empresa_id Int
  empresa    Empresa @relation(fields: [empresa_id], references: [id], onDelete: Cascade)

  itens Item[]

  @@unique([nome, empresa_id])
  @@index([empresa_id])
}

model Item {
  id            Int      @id @default(autoincrement())
  nome          String
  descricao     String?
  codigo_barras String?
  preco         Decimal  @db.Decimal(10, 2)
  tipo          ItemTipo @default(MERCADORIA)
  ativo         Boolean  @default(true)
  index         Int      @default(0) // para order
  tempo_preparo Int      @default(0) // em minutos
  imagem        String?

  empresa_id Int
  empresa    Empresa @relation(fields: [empresa_id], references: [id], onDelete: Cascade)

  subitens ItemSubitem[]

  classe_id Int?
  classe    Classe? @relation(fields: [classe_id], references: [id])

  promocao Promocao[]

  // Relação para combos
  combos_as_combo ComboItem[] @relation("ComboItens") // se este item é um combo que contém outros itens
  combos_as_item  ComboItem[] @relation("ItemInCombos") // se este item faz parte de algum combo

  // relação com vendas
  vendas PedidoItem[]

  grupo_fiscal_id Int?
  grupo_fiscal    GrupoFiscal? @relation(fields: [grupo_fiscal_id], references: [id])

  @@unique([nome, empresa_id])
  @@index([empresa_id])
}

enum ItemSubitemTipo {
  MATERIA_PRIMA
  ADICIONAL
  AMBOS
}

model ItemSubitem {
  item_id Int
  item    Item @relation(fields: [item_id], references: [id], onDelete: Cascade)

  subitem_id Int
  subitem    Subitem @relation(fields: [subitem_id], references: [id])

  tipo ItemSubitemTipo

  quantidade Decimal @db.Decimal(10, 3)

  preco Decimal? @db.Decimal(10, 2)

  @@id([item_id, subitem_id])
}

// --------- combos

model ComboItem {
  combo_id Int
  combo    Item @relation("ComboItens", fields: [combo_id], references: [id], onDelete: Cascade)

  item_id Int
  item    Item @relation("ItemInCombos", fields: [item_id], references: [id], onDelete: Cascade)

  quantidade Decimal @db.Decimal(10, 3)

  @@id([combo_id, item_id])
}

// ----------------------------------------------------------------------------------------------------------------------- estoque

enum EstoqueMovimentacaoTipo {
  ENTRADA
  SAIDA
  AJUSTE
  VENDA
}

model EstoqueMovimentacao {
  id String @id @default(uuid())

  subitem_id Int
  subitem    Subitem @relation(fields: [subitem_id], references: [id], onDelete: Cascade)

  tipo       EstoqueMovimentacaoTipo @default(ENTRADA)
  quantidade Decimal                 @default(0) @db.Decimal(10, 3)
  referencia String? //    pedido:123    compra:45    inventario:2026-03-16

  // Por que isso? Porque o custo do item muda. 
  // Daqui a um ano, você vai querer saber quanto pagou 
  // naquela ENTRADA específica de 2024.
  // REGRA DE OURO: O saldo no banco de dados deve ser SEMPRE na Unidade de Venda.
  custo_unitario_momento Decimal? @db.Decimal(10, 2)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  empresa_id Int
  empresa    Empresa @relation(fields: [empresa_id], references: [id], onDelete: Cascade)

  @@index([empresa_id])
}

model EstoquePosicao {
  id Int @id @default(autoincrement())

  // Relação com o seu Item/Produto existente
  subitem_id Int     @unique // @unique garante que cada item tenha apenas uma linha de posição
  subitem    Subitem @relation(fields: [subitem_id], references: [id], onDelete: Cascade)

  // Quantidades
  // REGRA DE OURO: O saldo no banco de dados deve ser SEMPRE na Unidade de Venda.
  // Se você tem 2 caixas de 12, no banco deve constar 24.
  // o ESTOQUE_ATUAL deve ser a quantidade_fisica - quantidade_reserva (reserva serve par deliveries, por exemplo)
  quantidade_fisica  Decimal @default(0) @db.Decimal(10, 3) // Usar Decimal para evitar erros de precisão (ex: kg)
  quantidade_reserva Decimal @default(0) @db.Decimal(10, 3) // Itens vendidos mas não despachados

  // Controle de Reposição
  estoque_minimo Decimal  @default(0) @db.Decimal(10, 3)
  estoque_maximo Decimal? @db.Decimal(10, 3)

  // Valores Financeiros (Opcional, mas recomendado para Posição de Estoque) REGRA DE OURO: O saldo no banco de dados deve ser SEMPRE na Unidade de Venda.
  // custoUnitario: É o valor que você pagou por uma unidade de venda do produto (já considerando o fator de conversão).
  custo_unitario Decimal @default(0) @db.Decimal(10, 2)

  // Auditoria
  ultima_contagem DateTime? // Data do último inventário físico
  updated_at      DateTime  @updatedAt
  created_at      DateTime  @default(now())

  empresa_id Int
  empresa    Empresa @relation(fields: [empresa_id], references: [id], onDelete: Cascade)

  @@index([empresa_id])
}

// ----------------------------------------------------------------------------------------------------------------------- promocoes

model Promocao {
  id         Int     @id @default(autoincrement())
  empresa_id Int
  empresa    Empresa @relation(fields: [empresa_id], references: [id], onDelete: Cascade)

  preco_promocional Decimal @db.Decimal(10, 2)
  hora_inicio       String // "18:00"
  hora_fim          String // "23:59"
  ativo             Boolean @default(true)

  // dia_da_semana_id    Int
  // dia_da_semana       DiaDaSemana @relation(fields: [dia_da_semana_id], references: [id], onDelete: Cascade)
  seg Boolean @default(false)
  ter Boolean @default(false)
  qua Boolean @default(false)
  qui Boolean @default(false)
  sex Boolean @default(false)
  sab Boolean @default(false)
  dom Boolean @default(false)

  item_id Int
  item    Item @relation(fields: [item_id], references: [id], onDelete: Cascade)

  @@index([empresa_id])
  @@index([item_id])
}

model DiaDaSemana {
  id             Int       @id
  nome_completo  String
  nome_abreviado String
  nome_enum      DayOfWeek

  horario_funcionamento HorarioDeFuncionamento[]
}

enum DayOfWeek {
  SEGUNDA
  TERCA
  QUARTA
  QUINTA
  SEXTA
  SABADO
  DOMINGO
}

// ----------------------------------------------------------------------------------------------------------------------- formatos de venda

// ------------------- mesa
model Mesa {
  id   Int    @id @default(autoincrement())
  nome String // Número da mesa (Ex: Mesa 01, Mesa 02)

  empresa_id Int
  empresa    Empresa @relation(fields: [empresa_id], references: [id], onDelete: Cascade)

  // posicionamento no mapa de mesas
  pos_x Float?
  pos_y Float?

  status MesaStatus @default(LIVRE)

  pedidos Pedido[]

  updated_at DateTime @updatedAt

  @@unique([nome, empresa_id])
  @@index([empresa_id])
}

enum MesaStatus {
  LIVRE // Livre
  OCUPADA // Ocupada (Cliente sentado)
  CONTA // Pediu a conta
}

// ------------------- comanda
model Comanda {
  id String @id @default(uuid())

  nome String?

  cliente_id Int?
  cliente    Cliente? @relation(fields: [cliente_id], references: [id])

  empresa_id Int
  empresa    Empresa @relation(fields: [empresa_id], references: [id], onDelete: Cascade)

  status ComandaStatus @default(OCUPADA)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  pedidos Pedido[]

  @@unique([nome, empresa_id])
  @@index([empresa_id])
}

enum ComandaStatus {
  OCUPADA // Ocupada (Cliente sentado)
  CONTA
  PAGA // pagou
}

// ------------------- senha
model Senha {
  id     String  @id @default(uuid())
  numero Int?
  nome   String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  empresa_id Int
  empresa    Empresa @relation(fields: [empresa_id], references: [id], onDelete: Cascade)

  pedidos Pedido[]

  @@unique([numero, empresa_id])
  @@index([empresa_id])
}

// ----------------------------------------------------------------------------------- EVENTOS
model Evento {
  id Int @id @default(autoincrement())

  nome      String
  descricao String?

  created_at DateTime @default(now())

  inicio DateTime
  final  DateTime

  imagem String?

  empresa_id Int
  empresa    Empresa @relation(fields: [empresa_id], references: [id], onDelete: Cascade)

  @@index([empresa_id])
}

// ----------------------------------------------------------------------------------------------------------------------- delivery

model Motoboy {
  id       Int     @id @default(autoincrement())
  nome     String
  telefone String
  ativo    Boolean @default(true)

  empresa_id Int
  empresa    Empresa @relation(fields: [empresa_id], references: [id], onDelete: Cascade)

  pedidos Pedido[]

  @@index([empresa_id])
}

model ZonaEntrega {
  id             Int     @id @default(autoincrement())
  nome           String  // "Centro", "Água Verde", "Zona Sul"
  cidade         String  @default("") // cidade à qual o bairro pertence
  taxa_base      Decimal @default(0) @db.Decimal(10, 2) // taxa fixa da empresa (repetida por zona para leitura única)
  taxa           Decimal @db.Decimal(10, 2)              // taxa variável por zona
  tempo_estimado Int     @default(30) // em minutos
  ativo          Boolean @default(true)

  empresa_id Int
  empresa    Empresa @relation(fields: [empresa_id], references: [id], onDelete: Cascade)

  pedidos Pedido[]

  @@unique([nome, cidade, empresa_id])
  @@index([empresa_id])
}

// ----------------------------------------------------------------------------------------------------------------------- pedidos (vendas)

enum PedidoStatus {
  PENDENTE
  PAGA
  CANCELADA
}

enum ProducaoStatus {
  AGUARDANDO
  EM_PREPARO
  PRONTO
}

enum PedidoFormato {
  BALCAO
  MESA
  SENHA
  COMANDA
  DELIVERY
}

model Pedido {
  id String @id @default(uuid())

  empresa_id Int
  empresa    Empresa @relation(fields: [empresa_id], references: [id], onDelete: Cascade)

  created_at DateTime     @default(now())
  updated_at DateTime     @updatedAt
  status     PedidoStatus @default(PENDENTE)
  total      Decimal      @db.Decimal(10, 2)
  desconto   Decimal      @default(0) @db.Decimal(10, 2) // desconto total da venda

  producao_status ProducaoStatus @default(AGUARDANDO)

  observacao String? // qualquer coisa que o cliente peca pro pedido todo

  itens PedidoItem[]

  // formato de trabalho = MESAS
  mesa_id String?
  mesa    Mesa?   @relation(fields: [mesa_id, empresa_id], references: [nome, empresa_id])

  // formato de trabalho = COMANDAS
  comanda_id String?
  comanda    Comanda? @relation(fields: [comanda_id], references: [id])

  // formato de trabalho = SENHAS
  senha_id     Int?
  senha_pronta Boolean @default(false)  // só relevante quando senha_id != null
  senha        Senha?  @relation(fields: [senha_id, empresa_id], references: [numero, empresa_id])

  // vai ser preenchido so quando a venda for terminada pra depois usarmos pra filtrar relatorios
  formato PedidoFormato?

  // vai ser preenchido so quando a venda for terminada pra depois usarmos pra filtrar relatorios
  terminal_id Int?
  terminal    Terminal? @relation(fields: [terminal_id], references: [id], onDelete: SetNull)

  cliente_id Int? // cliente quando for delivery
  cliente    Cliente? @relation(fields: [cliente_id], references: [id], onDelete: SetNull)

  // Delivery
  delivery_status     DeliveryStatus?
  cpf_nota            String?      // CPF do consumidor para nota fiscal (autoatendimento)
  canal_origem        CanalOrigem?
  taxa_entrega        Decimal?        @db.Decimal(10, 2)
  endereco_entrega_id Int?
  endereco_entrega    Endereco?       @relation("EnderecoEntrega", fields: [endereco_entrega_id], references: [id])
  motoboy_id          Int?
  motoboy             Motoboy?        @relation(fields: [motoboy_id], references: [id], onDelete: SetNull)
  zona_entrega_id     Int?
  zona_entrega        ZonaEntrega?    @relation(fields: [zona_entrega_id], references: [id], onDelete: SetNull)
  producao_inicio_at  DateTime?
  producao_fim_at     DateTime?
  saiu_at             DateTime?
  entregue_at         DateTime?

  usuario_id        Int
  usuario           Usuario           @relation(fields: [usuario_id], references: [id])
  pedido_pagamentos PedidoPagamento[]


  @@index([empresa_id, created_at])   // relatório principal
  @@index([empresa_id, status])       // filtro de status
  @@index([empresa_id, terminal_id])  // terminal
  @@index([empresa_id, usuario_id])   // operador
  @@index([empresa_id, delivery_status])
  @@index([empresa_id, producao_status])

  @@map("Pedido")
}

model PedidoItem {
  id        String @id @default(uuid())
  pedido_id String
  pedido    Pedido @relation(fields: [pedido_id], references: [id], onDelete: Cascade)

  observacao String? // qualquer coisa que o cliente peca pro item do pedido (sem alguma coisa ou esquentar mais , sei la)

  item_id Int
  item    Item @relation(fields: [item_id], references: [id])

  quantidade Decimal @db.Decimal(10, 3)
  preco      Decimal @db.Decimal(10, 2) // preço do item original
  desconto   Decimal @default(0) @db.Decimal(10, 2) // desconto aplicado nesse item específico

  subitens PedidoItemSubitem[]

  @@map("PedidoItem")
}

model PedidoItemSubitem {
  id             String     @id @default(uuid())
  pedido_item_id String
  pedido_item    PedidoItem @relation(fields: [pedido_item_id], references: [id], onDelete: Cascade)

  subitem_id Int
  subitem    Subitem @relation("PedidoItemSubitem_Subitem", fields: [subitem_id], references: [id])

  tipo     ItemSubitemTipo @default(MATERIA_PRIMA)
  removido Boolean         @default(false)

  quantidade Decimal @db.Decimal(10, 3)
  preco      Decimal @db.Decimal(10, 2)
  desconto   Decimal @default(0) @db.Decimal(10, 2)

  @@map("PedidoItemSubitem")
}

// ----------------------------------------------------------------------------------------------------------------------- pedidos (historico)

model VendaHistorico {
  id         String       @id @default(uuid())
  empresa_id Int

  created_at DateTime     @default(now())
  status     PedidoStatus @default(PENDENTE)

  total    Decimal @db.Decimal(10, 2)
  desconto Decimal @default(0) @db.Decimal(10, 2)

  // snapshot (segurança / auditoria)
  itens_json     Json
  pagamento_json Json?

  // snapshot usuário
  usuario_id    Int
  usuario_nome  String
  usuario_email String

  // snapshot terminal
  terminal_id   Int?
  terminal_nome String?

  // relações flat
  itens       VendaHistoricoItem[]
  subitens    VendaHistoricoSubitem[]
  pagamentos  VendaHistoricoPagamento[]

  // 🔥 ÍNDICES IMPORTANTES (relatórios)
  @@index([empresa_id, created_at])   // principal (relatório mensal)
  @@index([empresa_id, status])
  @@index([empresa_id, usuario_id])
  @@index([empresa_id, terminal_id])
}


model VendaHistoricoItem {
  id String @id @default(uuid())

  empresa_id        Int
  venda_historico_id String

  venda_historico VendaHistorico @relation(fields: [venda_historico_id], references: [id], onDelete: Cascade)

  // snapshot do item
  item_id   Int?
  nome      String
  classe_id Int?
  classe_nome String?

  quantidade Decimal @db.Decimal(10, 3)
  preco      Decimal @db.Decimal(10, 2)
  desconto   Decimal @default(0) @db.Decimal(10, 2)
  total      Decimal @db.Decimal(10, 2)

  created_at DateTime

  // 🔥 índices pra relatório
  @@index([empresa_id, created_at])
  @@index([empresa_id, item_id])
  @@index([empresa_id, classe_id])
}



model VendaHistoricoSubitem {
  id String @id @default(uuid())

  empresa_id         Int
  venda_historico_id String

  venda_historico VendaHistorico @relation(fields: [venda_historico_id], references: [id], onDelete: Cascade)

  subitem_id Int?
  nome       String

  quantidade Decimal @db.Decimal(10, 3)
  preco      Decimal @db.Decimal(10, 2)
  total      Decimal @db.Decimal(10, 2)

  created_at DateTime

  // 🔥 índices
  @@index([empresa_id, created_at])
  @@index([empresa_id, subitem_id])
}



model VendaHistoricoPagamento {
  id String @id @default(uuid())

  empresa_id         Int
  venda_historico_id String

  venda_historico VendaHistorico @relation(fields: [venda_historico_id], references: [id], onDelete: Cascade)

  valor         Decimal @db.Decimal(10, 2)
  valor_liquido Decimal @db.Decimal(10, 2)

  forma_pagamento String
  tipo_pagamento  TipoFormaPagamento?

  bandeira_cartao String?
  provedor_nome   String?

  parcelas Int?

  taxa_percentual Decimal? @db.Decimal(5, 2)
  taxa_valor      Decimal? @db.Decimal(10, 2)

  created_at DateTime

  // 🔥 índices
  @@index([empresa_id, created_at])
  @@index([empresa_id, forma_pagamento])
  @@index([empresa_id, tipo_pagamento])
}


